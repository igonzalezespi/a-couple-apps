{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && node .claude/hooks/format-on-write.mjs || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && [ -x node_modules/.bin/tsc ] && pnpm -s typecheck 2>&1 | tail -20 || true"
          }
        ]
      }
    ]
  }
}
