# A Couple Apps — environment template.
# Copy to .env (gitignored) and fill in. Secrets are NEVER committed.
# Validated by @aca/config parseEnv(); secret-bearing names are listed in
# SENSITIVE_ENV_VARS (packages/config/src/env.ts) and must never be logged.

# --- Supabase (one project, free tier) ---
# The URL is not secret; the anon key is.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- TMDB (movie data) ---
TMDB_API_KEY=your-tmdb-api-key

# --- Expo client (only EXPO_PUBLIC_* vars reach the app bundle) ---
# Expo loads .env from each app's own directory, so copy these into apps/<app>/.env
# (also gitignored) — not just this root file. The anon key is safe to ship in a
# client (Row Level Security enforces access); NEVER put a service-role key here.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
