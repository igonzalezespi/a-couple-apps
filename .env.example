# A Couple Apps — environment template.
# Copy to .env (gitignored) and fill in. Secrets are NEVER committed.
# Validated by @aca/config parseEnv(); secret-bearing names are listed in
# SENSITIVE_ENV_VARS (packages/config/src/env.ts) and must never be logged.

# --- Supabase (one project, free tier) ---
# The URL is not secret; the anon key is.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- TMDB (movie data) ---
TMDB_API_KEY=your-tmdb-api-key

# Note: Expo exposes only EXPO_PUBLIC_* vars to the client bundle. The data
# layer (Phase 5) reads these and mirrors client-needed values as EXPO_PUBLIC_*.
