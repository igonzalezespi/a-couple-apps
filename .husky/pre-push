# Fresh worktrees lack the gitignored couple.config.ts that app source imports,
# so typecheck below would fail before it ever runs real code. Seed it from the
# committed example (placeholders only); never commit the copy — it's gitignored.
if [ ! -f couple.config.ts ]; then
  cp couple.config.example.ts couple.config.ts
  echo "pre-push: seeded couple.config.ts from couple.config.example.ts (gitignored placeholder)"
fi

# Mirror the CI gate so a green push implies green CI.
pnpm install --frozen-lockfile
pnpm format:check
pnpm lint
pnpm typecheck
pnpm test
# Scan for secrets. Skip gracefully if gitleaks is not installed (CI enforces it
# non-bypassably), but never swallow a real detection.
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks detect --no-banner --redact --source .
else
  echo "gitleaks not installed; skipping local scan (CI enforces it)"
fi

# This is a PUBLIC repo: block any reference to a private project from reaching the remote.
# The denylist is private (studio repo only); no-op off-studio (fork, where ~/work is absent).
GUARD="${STUDIO_ROOT:-$HOME/work}/security/check-private-refs.sh"
if [ -x "$GUARD" ]; then
  git fetch origin develop --quiet 2>/dev/null || true
  CHANGED=$(git diff --name-only --diff-filter=ACM origin/develop...HEAD 2>/dev/null || true)
  # Explicit if: the previous `[ -n ... ] && guard` one-liner exited 1 on an empty
  # CHANGED (e.g. `git push --delete`), aborting the push with nothing to scan.
  if [ -n "$CHANGED" ]; then
    "$GUARD" $CHANGED
  fi
fi
