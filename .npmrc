engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false
prefer-offline=true

# Expo/Metro need a flat node_modules to resolve the React Native / Expo
# dependency graph. The package boundary is still enforced by the eslint
# no-restricted-imports rule, not by node resolution.
# INTENTIONAL-SPECIFIC: public repo (GitHub-hosted CI only) + Expo/Metro flat modules.
node-linker=hoisted
