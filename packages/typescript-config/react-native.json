{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Native (Expo)",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["expo", "node"],
    "allowJs": true
  }
}
